# Copy to .env and fill in your values. Never commit .env.

# Redshift
REDSHIFT_HOST=your-cluster.xxxxxxxxxxxx.eu-west-1.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB_NAME=your-database
REDSHIFT_USER_NAME=your-db-user
REDSHIFT_REGION=eu-west-1

# AWS credentials (only needed locally — on EC2 use an IAM role instead)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_PROFILE=your-profile
